# Optional override. If omitted, origin is auto-detected from request host (or VERCEL_URL fallback).
# DOMAIN=https://example.com
WP_DOMAIN=https://wp.example.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Set theme (default: "default")
THEME=default

# Cache TTL in seconds (default: 24 hours)
CACHE_TTL_SECONDS=86400
