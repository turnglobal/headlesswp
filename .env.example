# ------------------------------
# Required
# ------------------------------
WP_DOMAIN=https://wp.example.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_app_password

# ------------------------------
# Recommended
# ------------------------------
DOMAIN=https://www.example.com
REVALIDATE_SECRET=replace_with_a_long_random_secret

# ------------------------------
# Optional
# ------------------------------
THEME=default
CACHE_TTL_SECONDS=300
MEDIA_CACHE_TTL_SECONDS=604800
