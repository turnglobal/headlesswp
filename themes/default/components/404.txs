{{> header}}
<main id="main-content" class="max-w-3xl mx-auto px-6 py-16 md:py-20 text-center" tabindex="-1">
  <p class="text-xs uppercase text-muted mb-4">Error {{status}}</p>
  <h1 class="text-3xl md:text-4xl leading-tight mb-4">{{#if isGone}}This page is gone{{else}}Page not found{{/if}}</h1>
  <p class="text-muted">Path: <code>{{pathname}}</code></p>
  <a href="/" class="inline-block mt-8 px-6 py-3 rounded-full bg-black text-white dark:bg-white dark:text-black">Back to Home</a>
</main>
{{> footer}}
